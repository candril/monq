{
  "name": "monq",
  "version": "0.1.0",
  "description": "Terminal-based MongoDB browser and query tool",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/candril/monq.git"
  },
  "homepage": "https://github.com/candril/monq",
  "keywords": [
    "mongodb",
    "terminal",
    "tui",
    "cli",
    "database",
    "browser",
    "bun"
  ],
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "monq": "./dist/monq"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --compile --outfile dist/monq",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260329.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "0.1.87",
    "@opentui/react": "0.1.87",
    "json5": "^2.2.3",
    "mongodb": "^6.12.0",
    "react": "19",
    "snappy": "^7.3.3"
  }
}
