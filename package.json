{
  "name": "monq",
  "version": "0.1.0",
  "description": "Terminal-based MongoDB browser and query tool",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "monq": "./dist/monq"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --compile --outfile dist/monq",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.2.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "0.1.87",
    "@opentui/react": "0.1.87",
    "json5": "^2.2.3",
    "mongodb": "^6.12.0",
    "react": "19",
    "snappy": "^7.3.3"
  }
}
